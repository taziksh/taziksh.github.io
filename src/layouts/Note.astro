---
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  date: Date;
}
const { title, date } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
const dateHuman = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Tazik</title>
  </head>
  <body>
    <main class="note">
      <a class="back" href="/notes" aria-label="notes">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 10.5L12 3l9 7.5" />
          <path d="M5 9.5V21h14V9.5" />
        </svg>
      </a>
      <article>
        <header>
          <h1>{title}</h1>
          <time datetime={dateStr}>{dateHuman}</time>
        </header>
        <slot />
      </article>
    </main>

    <style is:global>
      :root {
        --bg: #ffffff;
        --ink: #222222;
        --ink-strong: #181818;
        --muted: #8a8a8a;
        --accent: #7b68ee;
        --code-bg: #f2f2f2;
        --code-ink: #3a3a3a;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1e1e1e;
          --ink: #dadada;
          --ink-strong: #eaeaea;
          --muted: #888888;
          --accent: #a18bf0;
          --code-bg: #2a2a2a;
          --code-ink: #cfcfcf;
        }
      }
      body {
        background: var(--bg);
        color: var(--ink);
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        line-height: 1.6;
      }

      .astro-code { background-color: var(--shiki-light-bg); }
      .astro-code,
      .astro-code span { color: var(--shiki-light); }
      @media (prefers-color-scheme: dark) {
        .astro-code { background-color: var(--shiki-dark-bg); }
        .astro-code,
        .astro-code span { color: var(--shiki-dark); }
      }
    </style>

    <style>
      .note {
        max-width: 680px;
        margin: 0 auto;
        padding: 3rem 1.5rem 6rem;
        box-sizing: border-box;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }
      .back {
        display: inline-flex;
        color: var(--muted);
      }
      .back svg { width: 18px; height: 18px; }
      .back:hover { color: var(--accent); }
      header { margin: 2.5rem 0 2rem; }
      h1 {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-weight: 500;
        font-size: 1.95rem;
        line-height: 1.15;
        margin: 0 0 0.4rem;
        color: var(--ink-strong);
      }
      time {
        font-size: 0.9rem;
        color: var(--muted);
      }
      article {
        font-size: 1.18rem;
        line-height: 1.75;
      }
      article :global(p) { margin: 0 0 1.35em; }
      article :global(ul),
      article :global(ol) { margin: 0 0 1.35em; padding-left: 1.4em; }
      article :global(li) { margin: 0.35em 0; }
      article :global(li > p) { margin: 0; }
      article :global(h2) {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-weight: 500;
        font-size: 1.45rem;
        line-height: 1.25;
        margin: 1.8em 0 0.5em;
        color: var(--ink-strong);
      }
      article :global(h3) {
        font-weight: 600;
        font-size: 1.2rem;
        margin: 1.6em 0 0.4em;
        color: var(--ink-strong);
      }
      article :global(blockquote) {
        position: relative;
        margin: 3rem 0;
        padding: 0;
        font-family: 'Fraunces', serif;
        font-size: 1.05em;
        line-height: 1.65;
        color: var(--ink-strong);
      }
      article :global(blockquote::before) {
        content: '\201C';
        position: absolute;
        left: -3rem;
        top: -0.4rem;
        font-family: 'Fraunces', serif;
        font-size: 3rem;
        line-height: 1;
        color: var(--accent);
      }
      article :global(blockquote p:last-child) { margin-bottom: 0; }
      @media (max-width: 800px) {
        article :global(blockquote) { padding-left: 2.4rem; }
        article :global(blockquote::before) { left: 0; }
      }
      article :global(hr) {
        border: 0;
        margin: 2.4rem 0;
        text-align: center;
        color: var(--muted);
      }
      article :global(hr::before) {
        content: '⁂';
        font-family: 'Fraunces', serif;
        font-size: 1.15rem;
        line-height: 1;
      }
      article :global(.katex) { font-size: 1.05em; }
      article :global(a) { color: var(--accent); }
      article :global(.image-caption) {
        display: block;
        width: fit-content;
        max-width: 100%;
        margin: -0.85em auto 1.6em;
        text-align: center;
        color: var(--muted);
        font-size: 0.72em;
        line-height: 1.35;
      }
      article :global(.image-caption a) {
        color: inherit;
        text-decoration-color: color-mix(in srgb, currentColor 45%, transparent);
      }
      article :global(.image-caption a:hover) {
        color: var(--accent);
      }
      article :global(.link-favicon) {
        display: inline-block;
        width: 0.95em;
        height: 0.95em;
        max-width: none;
        margin-left: 0.2em;
        vertical-align: -0.1em;
        object-fit: contain;
        border-radius: 2px;
      }
      article :global(.favicon-span) { white-space: nowrap; }
      article :global(pre) {
        background: var(--code-bg);
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        font-size: 0.85rem;
        line-height: 1.5;
      }
      article :global(:not(pre) > code) {
        background: var(--code-bg);
        padding: 0.1em 0.35em;
        border-radius: 4px;
        font-size: 0.9em;
      }
      article :global(img) {
        display: block;
        max-width: 100%;
        height: auto;
        margin-inline: auto;
        object-fit: contain;
        border-radius: 8px;
      }
      article :global(img[alt*='Cepheid']) {
        width: min(500px, 100%);
        height: min(333px, calc((100vw - 3rem) * 333 / 500));
        aspect-ratio: 479 / 319;
      }
      article :global(img[alt*='Leavitt']) {
        width: min(660px, 100%);
        height: min(439px, calc((100vw - 3rem) * 439 / 660));
        aspect-ratio: 479 / 319;
      }
      article :global(img[alt*='Light spreading']) {
        width: min(440px, 100%);
        height: min(293px, calc((100vw - 3rem) * 293 / 440));
        aspect-ratio: 479 / 319;
      }
      article :global(table) {
        border-collapse: collapse;
        margin: 0 auto 1.35em;
        font-size: 0.95em;
      }
      article :global(th),
      article :global(td) {
        padding: 0.35em 1.2em 0.35em 0;
        text-align: left;
      }
      article :global(th[align='right']),
      article :global(td[align='right']) { text-align: right; }
      article :global(th[align='center']),
      article :global(td[align='center']) { text-align: center; }
      article :global(th) {
        color: var(--ink-strong);
        border-bottom: 1px solid var(--code-bg);
      }

      @media (max-width: 480px) {
        .note { padding: 2.5rem 1.25rem 5rem; }
        h1 { font-size: 1.6rem; }
        article { font-size: 1.1rem; }
      }
    </style>
  </body>
</html>
