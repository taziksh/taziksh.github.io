---
const FEED = 'https://www.goodreads.com/review/list_rss/69012250?shelf=read';

// A review must be at least this many words to earn a spot on the page;
// one-liners like "lol" stay on Goodreads.
const MIN_REVIEW_WORDS = 50;

function wordCount(html) {
  return html.replace(/<[^>]*>/g, ' ').split(/\s+/).filter(Boolean).length;
}

function field(item, tag) {
  const m = item.match(new RegExp(`<${tag}>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?</${tag}>`, 's'));
  return m ? m[1].trim() : '';
}

import fs from 'node:fs';

// Goodreads caps each RSS page at 100 items; 6 parallel requests cover a
// 600-book shelf in one round-trip instead of sequential paging. The result
// is cached on disk so dev-server restarts (every file edit) don't trigger
// a refetch; production builds fetch once at build time.
const CACHE_FILE = '.astro/goodreads-cache.json';
const CACHE_TTL_MS = 30 * 60 * 1000;

let cache = { at: 0, books: null };
try {
  cache = JSON.parse(fs.readFileSync(CACHE_FILE, 'utf8'));
} catch {}

if (!cache.books || Date.now() - cache.at > CACHE_TTL_MS) {
  const pages = await Promise.all(
    [1, 2, 3, 4, 5, 6].map((page) =>
      fetch(`${FEED}&page=${page}`).then((res) => (res.ok ? res.text() : ''))
    )
  );
  const fetched = [];
  for (const xml of pages) {
    for (const item of xml.match(/<item>(.*?)<\/item>/gs) ?? []) {
      const review = field(item, 'user_review');
      if (!review || wordCount(review) < MIN_REVIEW_WORDS) continue;
      fetched.push({
        title: field(item, 'title'),
        author: field(item, 'author_name'),
        image: field(item, 'book_large_image_url'),
        review,
        link: field(item, 'link'),
      });
    }
  }
  cache = { at: Date.now(), books: fetched };
  try {
    fs.mkdirSync('.astro', { recursive: true });
    fs.writeFileSync(CACHE_FILE, JSON.stringify(cache));
  } catch {}
}
const books = cache.books;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500&display=swap"
      rel="stylesheet"
    />
    <title>Books | Tazik</title>
  </head>
  <body>
    <main class="books">
      <header>
        <a class="home" href="/" aria-label="home">~/</a>
        <h1>Books</h1>
      </header>
      {
        books.map((book) => (
          <details>
            <summary>
              <span class="marker">▸</span>
              <img class="cover" src={book.image} alt="" loading="lazy" />
              <span class="meta">
                <span class="title">{book.title}</span>
                <span class="author">{book.author}</span>
              </span>
            </summary>
            <div class="review" set:html={book.review} />
          </details>
        ))
      }
    </main>

    <style is:global>
      :root {
        --bg: #ffffff;
        --ink: #222222;
        --ink-strong: #181818;
        --muted: #8a8a8a;
        --accent: #7b68ee;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1e1e1e;
          --ink: #dadada;
          --ink-strong: #eaeaea;
          --muted: #888888;
          --accent: #a18bf0;
        }
      }
      body {
        background: var(--bg);
        color: var(--ink);
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        line-height: 1.6;
      }
    </style>

    <style>
      .books {
        max-width: 640px;
        margin: 0 auto;
        padding: 3rem 1.5rem 6rem;
      }
      .home {
        font-size: 1rem;
        color: var(--muted);
        text-decoration: none;
        display: inline-block;
        padding: 0.6rem 0.8rem;
        margin: -0.6rem -0.8rem;
      }
      .home:hover { color: var(--accent); }
      h1 {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-weight: 500;
        font-size: 1.95rem;
        margin: 2rem 0 0.25rem;
        color: var(--ink-strong);
      }
      .count {
        color: var(--muted);
        font-size: 0.9rem;
        margin: 0 0 2.5rem;
      }
      details {
        border-bottom: 1px solid color-mix(in srgb, var(--muted) 15%, transparent);
        padding: 1.1rem 0;
      }
      summary {
        display: flex;
        align-items: center;
        gap: 1rem;
        cursor: pointer;
        list-style: none;
      }
      summary::-webkit-details-marker { display: none; }
      .marker {
        color: var(--muted);
        font-size: 0.8rem;
        transition: transform 0.15s ease;
        flex-shrink: 0;
      }
      details[open] .marker { transform: rotate(90deg); }
      .cover {
        width: 44px;
        border-radius: 3px;
        display: block;
        flex-shrink: 0;
      }
      .meta { min-width: 0; }
      .title {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-size: 1.05rem;
        color: var(--accent);
        display: block;
      }
      summary:hover .title { text-decoration: underline; }
      .author {
        display: block;
        color: var(--muted);
        font-size: 0.85rem;
      }
      .review {
        margin: 0.9rem 0 0 calc(0.8rem + 1rem + 44px + 1rem);
        font-size: 0.92rem;
        color: var(--ink);
      }
    </style>
  </body>
</html>
