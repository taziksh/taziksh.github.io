---
import { getCollection, render } from 'astro:content';
import { isBookReview } from '../lib/notes';

const FEED = 'https://www.goodreads.com/review/list_rss/69012250?shelf=read';

// A review must be at least this many words to earn a spot on the page;
// one-liners like "lol" stay on Goodreads.
const MIN_REVIEW_WORDS = 50;

function wordCount(html) {
  return html.replace(/<[^>]*>/g, ' ').split(/\s+/).filter(Boolean).length;
}

function field(item, tag) {
  const m = item.match(new RegExp(`<${tag}>(?:<!\\[CDATA\\[)?(.*?)(?:\\]\\]>)?</${tag}>`, 's'));
  return m ? m[1].trim() : '';
}

import fs from 'node:fs';

// Goodreads caps each RSS page at 100 items; 6 parallel requests cover a
// 600-book shelf in one round-trip instead of sequential paging. The result
// is cached on disk so dev-server restarts (every file edit) don't trigger
// a refetch; production builds fetch once at build time.
const CACHE_FILE = '.astro/goodreads-cache.json';
const CACHE_TTL_MS = 30 * 60 * 1000;
const COVER_CACHE_FILE = '.astro/book-cover-cache.json';
const COVER_CACHE_VERSION = 2;

let cache = { at: 0, books: null };
try {
  cache = JSON.parse(fs.readFileSync(CACHE_FILE, 'utf8'));
} catch {}

if (!cache.books || Date.now() - cache.at > CACHE_TTL_MS) {
  const pages = await Promise.all(
    [1, 2, 3, 4, 5, 6].map((page) =>
      fetch(`${FEED}&page=${page}`).then((res) => (res.ok ? res.text() : ''))
    )
  );
  const fetched = [];
  for (const xml of pages) {
    for (const item of xml.match(/<item>(.*?)<\/item>/gs) ?? []) {
      const review = field(item, 'user_review');
      if (!review || wordCount(review) < MIN_REVIEW_WORDS) continue;
      fetched.push({
        title: field(item, 'title'),
        author: field(item, 'author_name'),
        image: field(item, 'book_large_image_url'),
        review,
        link: field(item, 'link'),
      });
    }
  }
  cache = { at: Date.now(), books: fetched };
  try {
    fs.mkdirSync('.astro', { recursive: true });
    fs.writeFileSync(CACHE_FILE, JSON.stringify(cache));
  } catch {}
}

let coverCache = {};
try {
  const storedCoverCache = JSON.parse(fs.readFileSync(COVER_CACHE_FILE, 'utf8'));
  if (storedCoverCache.version === COVER_CACHE_VERSION) {
    coverCache = storedCoverCache.covers ?? {};
  }
} catch {}

function normalized(value) {
  return value
    .normalize('NFKD')
    .replace(/[^\p{L}\p{N}]+/gu, ' ')
    .trim()
    .toLocaleLowerCase();
}

async function findCover(title, author) {
  const key = bookKey(title, author);
  if (coverCache[key]) return coverCache[key];

  const params = new URLSearchParams({
    title,
    fields:
      'key,title,author_name,editions,editions.key,editions.title,editions.cover_i,editions.language',
    limit: '5',
    lang: 'en',
  });
  if (author) params.set('author', author);

  try {
    const response = await fetch(`https://openlibrary.org/search.json?${params}`);
    if (!response.ok) return null;
    const result = await response.json();
    const wantedTitle = normalized(title);
    const wantedAuthor = normalized(author);
    const match = result.docs?.find((book) => {
      const foundTitle = normalized(book.title ?? '');
      const titleMatches =
        foundTitle === wantedTitle ||
        foundTitle.startsWith(`${wantedTitle} `) ||
        wantedTitle.startsWith(`${foundTitle} `);
      const authorMatches =
        !wantedAuthor ||
        book.author_name?.some((name) => normalized(name) === wantedAuthor);
      return titleMatches && authorMatches && book.editions?.docs?.[0]?.cover_i;
    });
    const coverId = match?.editions?.docs?.[0]?.cover_i;
    if (!coverId) return null;

    const image = `https://covers.openlibrary.org/b/id/${coverId}-M.jpg`;
    coverCache[key] = image;
    return image;
  } catch {
    return null;
  }
}

const localReviews = await Promise.all(
  (
    await getCollection(
      'notes',
      ({ data, id }) => data.public === true && isBookReview(id)
    )
  )
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map(async (note) => ({
      note,
      Content: (await render(note)).Content,
      image:
        note.data.cover ??
        note.data.image ??
        (await findCover(note.data.title, note.data.author ?? '')),
    }))
);

try {
  fs.mkdirSync('.astro', { recursive: true });
  fs.writeFileSync(
    COVER_CACHE_FILE,
    JSON.stringify({ version: COVER_CACHE_VERSION, covers: coverCache })
  );
} catch {}

function bookKey(title, author) {
  return `${title}\n${author}`.toLocaleLowerCase();
}

// A local review replaces the Goodreads copy of the same book.
const localBookKeys = new Set(
  localReviews.map(({ note }) => bookKey(note.data.title, note.data.author ?? ''))
);
const goodreadsBooks = cache.books.filter(
  (book) => !localBookKeys.has(bookKey(book.title, book.author))
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500&display=swap"
      rel="stylesheet"
    />
    <title>Books | Tazik</title>
  </head>
  <body>
    <main class="books">
      <header>
        <a class="home" href="/" aria-label="home">~/</a>
        <h1>Books</h1>
      </header>
      {
        localReviews.map(({ note, Content, image }) => (
          <details id={note.id.split('/').slice(1).join('/') || note.id}>
            <summary>
              {image ? (
                <img class="cover" src={image} alt="" loading="lazy" />
              ) : (
                <span class="cover cover-placeholder" aria-hidden="true">▤</span>
              )}
              <span class="meta">
                <span class="title">{note.data.title}</span>
                {note.data.author && <span class="author">{note.data.author}</span>}
              </span>
            </summary>
            <div class="review local-review"><Content /></div>
          </details>
        ))
      }
      {
        goodreadsBooks.map((book) => (
          <details>
            <summary>
              <img class="cover" src={book.image} alt="" loading="lazy" />
              <span class="meta">
                <span class="title">{book.title}</span>
                <span class="author">{book.author}</span>
              </span>
            </summary>
            <div class="review" set:html={book.review} />
          </details>
        ))
      }
    </main>

    <style is:global>
      :root {
        --bg: #ffffff;
        --ink: #222222;
        --ink-strong: #181818;
        --muted: #8a8a8a;
        --accent: #7b68ee;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1e1e1e;
          --ink: #dadada;
          --ink-strong: #eaeaea;
          --muted: #888888;
          --accent: #a18bf0;
        }
      }
      body {
        background: var(--bg);
        color: var(--ink);
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        line-height: 1.6;
      }
    </style>

    <style>
      .books {
        max-width: 640px;
        margin: 0 auto;
        padding: 3rem 1.5rem 6rem;
      }
      .home {
        font-size: 1rem;
        color: var(--muted);
        text-decoration: none;
        display: inline-block;
        padding: 0.6rem 0.8rem;
        margin: -0.6rem -0.8rem;
      }
      .home:hover { color: var(--accent); }
      h1 {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-weight: 500;
        font-size: 1.95rem;
        margin: 2rem 0 0.25rem;
        color: var(--ink-strong);
      }
      .count {
        color: var(--muted);
        font-size: 0.9rem;
        margin: 0 0 2.5rem;
      }
      details {
        border-bottom: 1px solid color-mix(in srgb, var(--muted) 15%, transparent);
        padding: 1.1rem 0;
      }
      summary {
        display: flex;
        align-items: center;
        gap: 1rem;
        cursor: pointer;
        list-style: none;
      }
      summary::-webkit-details-marker { display: none; }
      .cover {
        width: 44px;
        height: 66px;
        border-radius: 3px;
        display: block;
        flex-shrink: 0;
        object-fit: cover;
      }
      .cover-placeholder {
        box-sizing: border-box;
        display: grid;
        place-items: center;
        background: color-mix(in srgb, var(--muted) 12%, transparent);
        color: var(--muted);
        font-size: 1.2rem;
      }
      .meta { min-width: 0; }
      .title {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-size: 1.05rem;
        color: var(--accent);
        display: block;
      }
      summary:hover .title { text-decoration: underline; }
      .author {
        display: block;
        color: var(--muted);
        font-size: 0.85rem;
      }
      .review {
        margin: 0.9rem 0 0 calc(44px + 1rem);
        font-size: 0.92rem;
        color: var(--ink);
      }
      .local-review :global(p) { margin: 0 0 1em; }
      .local-review :global(p:last-child) { margin-bottom: 0; }
      .local-review :global(a) { color: var(--accent); }
      .local-review :global(img) {
        display: block;
        max-width: 100%;
        height: auto;
        border-radius: 6px;
      }
      .local-review :global(.image-caption) {
        display: block;
        width: fit-content;
        max-width: 100%;
        margin: -0.85em auto 1.6em;
        text-align: center;
        color: var(--muted);
        font-size: 0.72em;
        line-height: 1.35;
      }
      .local-review :global(.image-caption a) {
        color: inherit;
        text-decoration-color: color-mix(in srgb, currentColor 45%, transparent);
      }
      .local-review :global(.image-caption a:hover) { color: var(--accent); }
      .local-review :global(blockquote) {
        position: relative;
        margin: 3rem 0;
        padding: 0;
        font-size: 1.05em;
        line-height: 1.65;
        color: var(--ink-strong);
      }
      .local-review :global(blockquote p:last-child) { margin-bottom: 0; }
      .local-review :global(blockquote p:first-child::before),
      .local-review :global(blockquote p:last-child::after) {
        font-family: 'Fraunces', serif;
        font-size: 2.42em;
        line-height: 0;
        vertical-align: -0.35em;
        color: var(--accent);
      }
      .local-review :global(blockquote p:first-child::before) { content: '\201C\00A0'; }
      .local-review :global(blockquote p:last-child::after) { content: '\00A0\201D'; }
    </style>
  </body>
</html>
