---
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => data.public === true)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500&display=swap"
      rel="stylesheet"
    />
    <title>Notes | Tazik</title>
  </head>
  <body>
    <main class="notes">
      <header>
        <a class="home" href="/" aria-label="home">~/</a>
        <h1>Notes</h1>
      </header>
      <ul>
        {
          notes.map((note) => (
            <li>
              <a href={`/notes/${note.id}`}>{note.data.title}</a>
              <time datetime={note.data.date.toISOString().slice(0, 10)}>
                {note.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                  timeZone: 'UTC',
                })}
              </time>
            </li>
          ))
        }
      </ul>
    </main>

    <style is:global>
      :root {
        --bg: #ffffff;
        --ink: #222222;
        --ink-strong: #181818;
        --muted: #8a8a8a;
        --accent: #7b68ee;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1e1e1e;
          --ink: #dadada;
          --ink-strong: #eaeaea;
          --muted: #888888;
          --accent: #a18bf0;
        }
      }
      body {
        background: var(--bg);
        color: var(--ink);
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        line-height: 1.6;
      }
    </style>

    <style>
      .notes {
        max-width: 640px;
        margin: 0 auto;
        padding: 3rem 1.5rem 6rem;
      }
      .home {
        font-size: 1rem;
        color: var(--muted);
        text-decoration: none;
        display: inline-block;
        padding: 0.6rem 0.8rem;
        margin: -0.6rem -0.8rem;
      }
      .home:hover { color: var(--accent); }
      h1 {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-weight: 500;
        font-size: 1.95rem;
        margin: 2rem 0 2.5rem;
        color: var(--ink-strong);
      }
      ul { list-style: none; padding: 0; margin: 0; }
      li {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        padding: 0.5rem 0;
      }
      li a {
        font-family: 'Fraunces', serif;
        font-optical-sizing: auto;
        font-size: 1.1rem;
        color: var(--accent);
        text-decoration: none;
      }
      li a:hover { text-decoration: underline; }
      li time { font-size: 0.9rem; color: var(--muted); flex-shrink: 0; }
    </style>
  </body>
</html>
